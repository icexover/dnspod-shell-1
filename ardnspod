################################################################### error codes ##

# Unified error code constants
# All functions use these codes to report status consistently.

AR_ERR_OK=0                # Success
AR_ERR_GENERAL=1           # Generic / unspecified failure
AR_ERR_NETWORK=2           # Network failure (curl/wget could not reach server)
AR_ERR_API=3               # API returned an error response
AR_ERR_NO_TOOL=4           # Neither curl nor wget is available
AR_ERR_INVALID_IP=5        # IP address validation failed
AR_ERR_NO_IP=6             # Could not obtain IP address
AR_ERR_NOT_FOUND=7         # DNS record not found (may trigger creation)
AR_ERR_UNCHANGED=0         # Record unchanged (default: treat as success)

################################################################### defaults ##

# Default configuration values.
# Call arInit to override these; avoid relying on global export.

_arToken=""
_arIp4QueryUrl="http://ipv4.rehi.org/ip"
_arIp6QueryUrl="http://ipv6.rehi.org/ip"
_arLastRecordFile="/tmp/ardnspod_last_record"
_arErrCodeUnchanged=0
_arIsCreateRecord=0

# Backward-compatible exported globals (deprecated; use arInit).
# These are kept so that existing ddnspod.sh scripts continue to work
# without modification.  When arInit is called, the _ar* private vars
# take precedence.

export arToken
export arIp4QueryUrl="http://ipv4.rehi.org/ip"
export arIp6QueryUrl="http://ipv6.rehi.org/ip"
export arLastRecordFile=/tmp/ardnspod_last_record
export arErrCodeUnchanged=0
export arIsCreateRecord=0

################################################################### init ##

# Initialise the library with explicit parameters.
# This removes the need for global-variable coupling.
#
# Args: token [ip4QueryUrl] [ip6QueryUrl] [lastRecordFile] [errCodeUnchanged] [isCreateRecord]
#
# Example:
#   arInit "12345,abcdef..." \
#          "http://ipv4.rehi.org/ip" \
#          "http://ipv6.rehi.org/ip" \
#          "/tmp/ardnspod_last_record" \
#          0 0

arInit() {
    _arToken="${1:?arInit: token is required}"
    [ -n "$2" ] && _arIp4QueryUrl="$2"
    [ -n "$3" ] && _arIp6QueryUrl="$3"
    [ -n "$4" ] && _arLastRecordFile="$4"
    [ -n "$5" ] && _arErrCodeUnchanged="$5"
    [ -n "$6" ] && _arIsCreateRecord="$6"

    # Sync legacy globals so old code paths still see the values
    arToken="$_arToken"
    arIp4QueryUrl="$_arIp4QueryUrl"
    arIp6QueryUrl="$_arIp6QueryUrl"
    arLastRecordFile="$_arLastRecordFile"
    arErrCodeUnchanged="$_arErrCodeUnchanged"
    arIsCreateRecord="$_arIsCreateRecord"
}

# Internal helper: resolve effective config value.
# Prefers _ar* private var; falls back to legacy exported global.

_arConfig() {
    local key="$1"
    local val
    case "$key" in
        token)           val="${_arToken:-$arToken}" ;;
        ip4QueryUrl)     val="${_arIp4QueryUrl:-$arIp4QueryUrl}" ;;
        ip6QueryUrl)     val="${_arIp6QueryUrl:-$arIp6QueryUrl}" ;;
        lastRecordFile)  val="${_arLastRecordFile:-$arLastRecordFile}" ;;
        errCodeUnchanged) val="${_arErrCodeUnchanged:-$arErrCodeUnchanged}" ;;
        isCreateRecord)  val="${_arIsCreateRecord:-$arIsCreateRecord}" ;;
    esac
    echo "$val"
}

################################################################### logger ##

# Output log to stderr

arLog() {

    >&2 echo "$@"

}

################################################################### http client ##

# Use curl or wget to open a URL.
# Args: url [postdata]
#
# Return codes:
#   0 (AR_ERR_OK)      - request succeeded, body printed to stdout
#   2 (AR_ERR_NETWORK)  - network / transport failure
#   4 (AR_ERR_NO_TOOL)  - neither curl nor wget available

arRequest() {

    local url="$1"
    local data="$2"

    local params=""
    local agent="AnripDdns/6.5.0(wang@rehiy.com)"

    if type curl >/dev/null 2>&1; then
        if echo $url | grep -q https; then
            params="$params -k"
        fi
        if [ -n "$data" ]; then
            params="$params -d $data"
        fi
        local output rc
        output=$(curl -s -f -A "$agent" $params $url 2>/dev/null)
        rc=$?
        if [ $rc -ne 0 ]; then
            return $AR_ERR_NETWORK
        fi
        echo "$output"
        return $AR_ERR_OK
    fi

    if type wget >/dev/null 2>&1; then
        if echo $url | grep -q https; then
            params="$params --no-check-certificate"
        fi
        if [ -n "$data" ]; then
            params="$params --post-data $data"
        fi
        local output rc
        output=$(wget -qO- -U "$agent" $params $url 2>/dev/null)
        rc=$?
        if [ $rc -ne 0 ]; then
            return $AR_ERR_NETWORK
        fi
        echo "$output"
        return $AR_ERR_OK
    fi

    return $AR_ERR_NO_TOOL

}

################################################################### api response helpers ##

# ---- Common JSON parsing & error handling ----
# These helpers eliminate the duplicated sed-based JSON parsing that
# appeared in arDdnsLookup, arDdnsUpdate, and arDdnsCreate.

# Extract the status code from a DNSPod JSON response.
# Args: jsonResponse

arApiGetCode() {
    echo "$1" | sed 's/.*{"code":"\([0-9]*\)".*/\1/'
}

# Extract the error/info message from a DNSPod JSON response.
# Args: jsonResponse

arApiGetMessage() {
    echo "$1" | sed 's/.*"message":"\([^"]*\)".*/\1/'
}

# Extract the first "id" field from a DNSPod JSON response.
# Args: jsonResponse

arApiGetId() {
    echo "$1" | sed 's/.*"id":"\([0-9]*\)".*/\1/'
}

# Extract the record "value" (IP) from a DNSPod JSON response.
# Args: jsonResponse

arApiGetValue() {
    echo "$1" | sed 's/.*,"value":"\([0-9a-fA-F\.\:]*\)".*/\1/'
}

# Check whether an API response indicates success (code == "1").
# If not, log the error message and return AR_ERR_API.
# Args: jsonResponse contextLabel
# Returns: 0 on success, AR_ERR_API on failure

arApiCheckResponse() {
    local rs="$1"
    local label="$2"
    local code msg

    code=$(arApiGetCode "$rs")
    if [ "$code" != "1" ]; then
        msg=$(arApiGetMessage "$rs")
        arLog "> $label - API error (code=$code): $msg"
        return $AR_ERR_API
    fi
    return $AR_ERR_OK
}

################################################################### ipv4 util ##

# Get regular expression for IPv4 LAN addresses

arLanIp4() {

    local lanIps="^$"

    lanIps="$lanIps|(^10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$)"            # RFC1918
    lanIps="$lanIps|(^100\.(6[4-9]|[7-9][0-9])\.[0-9]{1,3}\.[0-9]{1,3}$)"  # RFC6598 100.64.x.x - 100.99.x.x
    lanIps="$lanIps|(^100\.1([0-1][0-9]|2[0-7])\.[0-9]{1,3}\.[0-9]{1,3}$)" # RFC6598 100.100.x.x - 100.127.x.x
    lanIps="$lanIps|(^127\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$)"           # RFC1122
    lanIps="$lanIps|(^169\.254\.[0-9]{1,3}\.[0-9]{1,3}$)"                  # RFC3927
    lanIps="$lanIps|(^172\.(1[6-9]|2[0-9]|3[0-1])\.[0-9]{1,3}\.[0-9]{1,3}$)" # RFC1918
    lanIps="$lanIps|(^192\.0\.2\.[0-9]{1,3}$)"                             # RFC5737
    lanIps="$lanIps|(^192\.168\.[0-9]{1,3}\.[0-9]{1,3}$)"                  # RFC1918
    lanIps="$lanIps|(^198\.1[8-9]\.[0-9]{1,3}\.[0-9]{1,3}$)"               # RFC2544
    lanIps="$lanIps|(^198\.51\.100\.[0-9]{1,3}$)"                          # RFC5737
    lanIps="$lanIps|(^203\.0\.113\.[0-9]{1,3}$)"                           # RFC5737
    lanIps="$lanIps|(^2[4-5][0-9]\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$)"   # RFC1112

    echo $lanIps

}

# Get IPv4 by ip route or network
#
# Return codes:
#   0 (AR_ERR_OK)         - success, IP printed to stdout
#   2 (AR_ERR_NETWORK)    - could not reach query service (via arRequest)
#   5 (AR_ERR_INVALID_IP) - obtained value is not a valid IPv4
#   6 (AR_ERR_NO_IP)      - no IP could be determined

arWanIp4() {

    local hostIp
    local lanIps=$(arLanIp4)

    case $(uname) in
        'Linux')
            hostIp=$(ip -o -4 route get 100.64.0.1 | grep -oE 'src [0-9\.]+' | awk '{print $2}' | grep -Ev "$lanIps")
        ;;
        Darwin|FreeBSD)
            hostIp=$(ifconfig | grep "inet " | grep -v 127.0.0.1 | awk '{print $2}' | grep -Ev "$lanIps")
        ;;
    esac

    if [ -z "$hostIp" ]; then
        local ip4Url=$(_arConfig ip4QueryUrl)
        hostIp=$(arRequest "$ip4Url")
        if [ $? -ne 0 ]; then
            return $AR_ERR_NETWORK
        fi
    fi

    if [ -z "$hostIp" ]; then
        return $AR_ERR_NO_IP
    fi

    if [ -z "$(echo $hostIp | grep -E '^[0-9\.]+$')" ]; then
        arLog "> arWanIp4 - Invalid ip address"
        return $AR_ERR_INVALID_IP
    fi

    echo $hostIp

}

# Get IPv4 from a specific interface
# Args: interface

arDevIp4() {

    local hostIp
    local lanIps=$(arLanIp4)

    case $(uname) in
        'Linux')
            hostIp=$(ip -o -4 addr show dev $1 primary | grep -oE 'inet [0-9.]+' | awk '{print $2}' | grep -Ev "$lanIps" | head -n 1)
        ;;
    esac

    if [ -z "$hostIp" ]; then
        arLog "> arDevIp4 - Can't get ip address"
        return $AR_ERR_NO_IP
    fi

    if [ -z "$(echo $hostIp | grep -E '^[0-9\.]+$')" ]; then
        arLog "> arDevIp4 - Invalid ip address"
        return $AR_ERR_INVALID_IP
    fi

    echo $hostIp

}

################################################################### ipv6 util ##

# Get regular expression for IPv6 LAN addresses

arLanIp6() {

    local lanIps="(^$)"

    lanIps="$lanIps|(^::1$)"                            # RFC4291
    lanIps="$lanIps|(^64:[fF][fF]9[bB]:)"               # RFC6052, RFC8215
    lanIps="$lanIps|(^100::)"                           # RFC6666
    lanIps="$lanIps|(^2001:2:0?:)"                      # RFC5180
    lanIps="$lanIps|(^2001:[dD][bB]8:)"                 # RFC3849
    lanIps="$lanIps|(^[fF][cdCD][0-9a-fA-F]{2}:)"       # RFC4193 Unique local addresses
    lanIps="$lanIps|(^[fF][eE][8-9a-bA-B][0-9a-fA-F]:)" # RFC4291 Link-local addresses

    echo $lanIps

}

# Get IPv6 by ip route or network

arWanIp6() {

    local hostIp
    local lanIps=$(arLanIp6)

    case $(uname) in
        'Linux')
            hostIp=$(ip -o -6 route get 100::1 | grep -oE 'src [0-9a-fA-F:]+' | awk '{print $2}' | grep -Ev "$lanIps")
        ;;
    esac

    if [ -z "$hostIp" ]; then
        local ip6Url=$(_arConfig ip6QueryUrl)
        hostIp=$(arRequest "$ip6Url")
        if [ $? -ne 0 ]; then
            return $AR_ERR_NETWORK
        fi
    fi

    if [ -z "$hostIp" ]; then
        arLog "> arWanIp6 - Can't get ip address"
        return $AR_ERR_NO_IP
    fi

    if [ -z "$(echo $hostIp | grep -E '^[0-9a-fA-F:]+$')" ]; then
        arLog "> arWanIp6 - Invalid ip address"
        return $AR_ERR_INVALID_IP
    fi

    echo $hostIp

}

# Get IPv6 from a specific interface
# Args: interface

arDevIp6() {

    local hostIp
    local lanIps=$(arLanIp6)

    case $(uname) in
        'Linux')
            # Try obtain home address (a speical permanent address for mobile devices)
            hostIp=$(ip -o -6 addr show dev $1 scope global home | grep -oE 'inet6 [0-9a-fA-F:]+' | awk '{print $2}' | grep -Ev "$lanIps")
            if [ -z "$hostIp" ]; then # Try obtain permanent address
                hostIp=$(ip -o -6 addr show dev $1 scope global permanent | grep -oE 'inet6 [0-9a-fA-F:]+' | awk '{print $2}' | grep -Ev "$lanIps")
            fi
            if [ -z "$hostIp" ]; then # Try obtain non-deprecated primary (non-temporary) non-mngtmpaddr (mngtmpaddr is template for temporary address creation) address then
                hostIp=$(ip -o -6 addr show dev $1 scope global -deprecated primary | grep -v mngtmpaddr | grep -oE 'inet6 [0-9a-fA-F:]+' | awk '{print $2}' | grep -Ev "$lanIps")
            fi
            if [ -z "$hostIp" ]; then # Try obtain non-deprecated primary address then
                hostIp=$(ip -o -6 addr show dev $1 scope global -deprecated primary | grep -oE 'inet6 [0-9a-fA-F:]+' | awk '{print $2}' | grep -Ev "$lanIps")
            fi
            if [ -z "$hostIp" ]; then # Try obtain non-deprecated address any at last
                hostIp=$(ip -o -6 addr show dev $1 scope global -deprecated | grep -oE 'inet6 [0-9a-fA-F:]+' | awk '{print $2}' | grep -Ev "$lanIps")
            fi
            hostIp=$(echo "$hostIp" | head -n 1) # Fetch at most one address
        ;;
    esac

    if [ -z "$hostIp" ]; then
        arLog "> arDevIp6 - Can't get ip address"
        return $AR_ERR_NO_IP
    fi

    if [ -z "$(echo $hostIp | grep -E '^[0-9a-fA-F:]+$')" ]; then
        arLog "> arDevIp6 - Invalid ip address"
        return $AR_ERR_INVALID_IP
    fi

    echo $hostIp

}

################################################################### dnspod api ##

# Dnspod Bridge — sends a request to the DNSPod API.
# Args: apiPath postData
#
# The token is read from the internal config (set via arInit or legacy
# global arToken).  The caller does not need to include login_token.

arDdnsApi() {

    local token=$(_arConfig token)
    local dnsapi="https://dnsapi.cn/${1:?'Info.Version'}"
    local params="login_token=$token&format=json&lang=en&$2"

    local rs rc
    rs=$(arRequest "$dnsapi" "$params")
    rc=$?
    if [ $rc -ne 0 ]; then
        arLog "> arDdnsApi - request failed (code=$rc)"
        return $rc
    fi
    echo "$rs"
    return $AR_ERR_OK

}

# Fetch Record Id
# Args: domain subdomain recordType
#
# Returns:
#   stdout  - the recordId on success
#   code 0  - success
#   code 7  - record not found (AR_ERR_NOT_FOUND, may trigger creation)
#   code 3  - API error

arDdnsLookup() {

    local subDomainRule=""
    local recordId
    local errMsg
    local isCreateRecord=$(_arConfig isCreateRecord)

    if [ "$2" != "@" ]; then
        subDomainRule="&sub_domain=$2"
    fi

    recordId=$(arDdnsApi "Record.List" "domain=$1${subDomainRule}&record_type=$3")
    if [ $? -ne 0 ]; then
        return $?
    fi

    # Use common parser
    local extractedId
    extractedId=$(arApiGetId "$recordId")

    if [ "$extractedId" -gt 0 ] 2>/dev/null; then
        echo "$extractedId"
        return $AR_ERR_OK
    fi

    # Record not found — extract error message
    errMsg=$(arApiGetMessage "$recordId")
    arLog "> arDdnsLookup - $errMsg"
    if [ "$isCreateRecord" -eq 1 ] && [ "$errMsg" = "No records on the list" ]; then
        return $AR_ERR_NOT_FOUND
    fi
    return $AR_ERR_API

}

# Update Record Value
# Args: domain subdomain recordId recordType [hostIp]

arDdnsUpdate() {

    local recordRs
    local recordIp
    local rc
    local lastRecordFile="$(_arConfig lastRecordFile).$3"
    local errCodeUnchanged=$(_arConfig errCodeUnchanged)

    local lastRecordIp

    # fetch last ip from cache file
    if [ -f "$lastRecordFile" ]; then
        lastRecordIp=$(cat "$lastRecordFile")
    fi

    # fetch from api if cache is empty
    if [ -z "$lastRecordIp" ]; then
        recordRs=$(arDdnsApi "Record.Info" "domain=$1&record_id=$3")
        rc=$?
        if [ $rc -ne 0 ]; then
            arLog "> arDdnsUpdate - failed to fetch current record (code=$rc)"
            return $rc
        fi
        arApiCheckResponse "$recordRs" "arDdnsUpdate:Record.Info" || return $?
        lastRecordIp=$(arApiGetValue "$recordRs")
    fi

    # update ip
    local ddnsParams="domain=$1&sub_domain=$2&record_id=$3&record_type=$4&record_line=%e9%bb%98%e8%ae%a4"
    if [ -z "$5" ]; then
        recordRs=$(arDdnsApi "Record.Ddns" "$ddnsParams")
    else
        if [ "$5" = "$lastRecordIp" ]; then
            arLog "> arDdnsUpdate - unchanged: $lastRecordIp"
            return $errCodeUnchanged
        fi
        recordRs=$(arDdnsApi "Record.Ddns" "$ddnsParams&value=$5")
    fi
    rc=$?
    if [ $rc -ne 0 ]; then
        arLog "> arDdnsUpdate - request failed (code=$rc)"
        return $rc
    fi

    # check result using common helper
    arApiCheckResponse "$recordRs" "arDdnsUpdate" || return $?
    recordIp=$(arApiGetValue "$recordRs")

    if [ "$recordIp" = "$lastRecordIp" ]; then
        arLog "> arDdnsUpdate - unchanged: $recordIp"
        return $errCodeUnchanged
    else
        arLog "> arDdnsUpdate - updated: $recordIp"
        if [ -n "$lastRecordFile" ]; then
            echo "$recordIp" > "$lastRecordFile"
        fi
        return $AR_ERR_OK
    fi

}

# Create Record
# Args: domain subdomain recordType hostIp

arDdnsCreate() {

    local recordRs
    local recordId

    recordRs=$(arDdnsApi "Record.Create" "domain=$1&sub_domain=$2&record_type=$3&value=$4&record_line=%e9%bb%98%e8%ae%a4")
    if [ $? -ne 0 ]; then
        return $?
    fi

    # check result using common helper
    arApiCheckResponse "$recordRs" "arDdnsCreate" || return $?
    recordId=$(arApiGetId "$recordRs")

    arLog "> arDdnsCreate - created: $4"
    echo "$recordId"
    return $AR_ERR_OK

}

################################################################### task hub ##

# ---- arDdnsCheck sub-tasks ----
# arDdnsCheck has been decomposed into small, focused helpers so that
# each step (get IP, lookup record, update record) is independently
# testable and maintainable.

# Step 1: Obtain the host IP address.
# Args: version(4|6) interface
# Prints: hostIp
# Returns: 0 on success, or a specific error code

_arDdnsGetHostIp() {
    local version="$1"
    local iface="$2"

    if   [ "$version" = "6" ] && [ -n "$iface" ]; then
        arDevIp6 "$iface"
    elif [ "$version" = "4" ] && [ -n "$iface" ]; then
        arDevIp4 "$iface"
    elif [ "$version" = "6" ]; then
        arWanIp6
    else
        arWanIp4
    fi
}

# Step 2: Resolve the recordId (create if needed).
# Args: domain subdomain recordType
# Prints: recordId
# Returns: 0 on success

_arDdnsFetchRecordId() {
    local domain="$1"
    local subdomain="$2"
    local recordType="$3"

    local recordId errCode isCreateRecord=$(_arConfig isCreateRecord)

    arLog "Fetching RecordId"
    recordId=$(arDdnsLookup "$domain" "$subdomain" "$recordType")
    errCode=$?

    if [ $errCode -eq 0 ]; then
        arLog "> Record Id: $recordId"
        echo "$recordId"
        return $AR_ERR_OK
    fi

    if [ $errCode -eq $AR_ERR_NOT_FOUND ] && [ "$isCreateRecord" -eq 1 ]; then
        arLog "Creating Record value"
        recordId=$(arDdnsCreate "$domain" "$subdomain" "$recordType" "")
        errCode=$?
        if [ $errCode -eq 0 ]; then
            arLog "> Record Id: $recordId"
            echo "$recordId"
            return $AR_ERR_OK
        fi
        arLog "$recordId"
        return $errCode
    fi

    arLog "$recordId"
    return $errCode
}

# Step 3: Update the DNS record with the current IP.
# Args: domain subdomain recordId recordType hostIp

_arDdnsApplyUpdate() {
    local domain="$1"
    local subdomain="$2"
    local recordId="$3"
    local recordType="$4"
    local hostIp="$5"

    arLog "Updating Record value"
    arDdnsUpdate "$domain" "$subdomain" "$recordId" "$recordType" "$hostIp"
}

# DDNS Check (public entry-point)
# Args: domain subdomain [6|4] [interface]

arDdnsCheck() {

    local domain="$1"
    local subdomain="$2"
    local version="${3:-4}"
    local iface="$4"

    local hostIp recordId recordType
    local errCode

    arLog "=== Check $subdomain.$domain ==="

    # --- Determine record type ---
    if [ "$version" = "6" ]; then
        recordType=AAAA
    else
        recordType=A
    fi

    # --- Step 1: Get host IP ---
    arLog "Fetching Host Ip"
    hostIp=$(_arDdnsGetHostIp "$version" "$iface")
    errCode=$?

    if [ $errCode -eq 0 ]; then
        arLog "> Host Ip: $hostIp"
        arLog "> Record Type: $recordType"
    elif [ $errCode -eq $AR_ERR_NETWORK ]; then
        arLog "> Host Ip: Auto"
        arLog "> Record Type: $recordType"
        hostIp=""  # let the API decide
    else
        arLog "$hostIp"
        return $errCode
    fi

    # --- Step 2: Fetch record ID ---
    recordId=$(_arDdnsFetchRecordId "$domain" "$subdomain" "$recordType")
    errCode=$?
    if [ $errCode -ne 0 ]; then
        return $errCode
    fi

    # --- Step 3: Update record ---
    _arDdnsApplyUpdate "$domain" "$subdomain" "$recordId" "$recordType" "$hostIp"

}

################################################################### end ##
